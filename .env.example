# --- Database -------------------------------------------------------------
# Postgres connection string (Bun.SQL + drizzle-kit both read this)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# --- Better Auth ----------------------------------------------------------
# Run `openssl rand -base64 32` to generate a secret (>= 32 chars)
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
# Public URL of the server (where auth cookies are issued)
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated origins allowed to call the API (your frontend)
TRUSTED_ORIGINS=http://localhost:5173
# Require users to verify their email before signing in (true/false)
REQUIRE_EMAIL_VERIFICATION=true

# --- Google OAuth ---------------------------------------------------------
# From Google Cloud Console > Credentials > OAuth client ID (Web application).
# Authorized redirect URI must be:  {BETTER_AUTH_URL}/api/auth/callback/google
# Leave blank to disable the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (SMTP) ---------------------------------------------------------
# Defaults target Resend's SMTP. Swap host/user/pass for any SMTP provider.
# Resend:  host=smtp.resend.com  port=465  user=resend  pass=<your re_... key>
# If SMTP_PASS is empty, emails are logged to the console instead of sent.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
# Must be an address on a domain you've verified in Resend (or onboarding@resend.dev for testing)
EMAIL_FROM=onboarding@resend.dev

# --- Server ---------------------------------------------------------------
PORT=3000
