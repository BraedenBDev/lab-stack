{
  "name": "lab-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "bunx @better-auth/cli generate --config src/server/auth.ts --output src/server/db/auth-schema.ts -y"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "better-auth": "^1.4.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.9.0",
    "nodemailer": "^9.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "^1.3.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "drizzle-kit": "^0.31.0",
    "lucide-react": "^0.544.0",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
